@{
    ViewData["Title"] = "Login";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">Login</h4>
                </div>
                <div class="card-body p-4">
                    @if (ViewBag.Error != null)
                    {
                        <div class="alert alert-danger" role="alert">
                            @ViewBag.Error
                        </div>
                    }

                    <form method="post" action="/Auth/Login">
                        <div class="mb-3">
                            <label for="username" class="form-label">Username/Email</label>
                            <input type="text" class="form-control" id="username" name="username" placeholder="Enter username or email" required>
                            <small class="form-text text-muted">
                                Admin: <strong>admin</strong> | LoanApprover: <strong>loanapprover</strong> | Customer: Enter your email
                            </small>
                        </div>

                        <div class="mb-3">
                            <label for="password" class="form-label">Password</label>
                            <input type="password" class="form-control" id="password" name="password" placeholder="Enter password" required>
                            <small class="form-text text-muted">
                                Admin: <strong>admin123</strong> | LoanApprover: <strong>loanapprover123</strong> | Customer: Enter your email
                            </small>
                        </div>

                        <button type="submit" class="btn btn-primary w-100">Login</button>
                    </form>

                    <hr>

                    <p class="text-center">Don't have an account? <a href="/Auth/Register">Register here</a></p>
                </div>
            </div>
        </div>
    </div>
</div>
