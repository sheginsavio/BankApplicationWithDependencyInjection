        // GET: Transaction/Withdraw
        public IActionResult Withdraw()
        {
            // Check if customer is logged in
            if (!IsCustomerLoggedIn())
            {
                return RedirectToAction("Login", "Auth");
            }

            var customerId = GetCurrentCustomerId();

            // Get customer's accounts
            var accounts = _context.Accounts
                .Where(a => a.CustomerId == customerId)
                .ToList();

            if (accounts.Count == 0)
            {
                ViewBag.Error = "You have no accounts. Please create an account first.";
                return View();
            }

            return View(accounts);
        }

        // POST: Transaction/Withdraw
        [HttpPost]
        public IActionResult Withdraw(int accountId, decimal amount)
        {
            // Check if customer is logged in
            if (!IsCustomerLoggedIn())
            {
                return RedirectToAction("Login", "Auth");
            }

            var customerId = GetCurrentCustomerId();

            // Validate amount
            if (amount <= 0)
            {
                ViewBag.Error = "Withdrawal amount must be greater than 0.";
                var accounts = _context.Accounts
                    .Where(a => a.CustomerId == customerId)
                    .ToList();
                return View(accounts);
            }

            // Get account
            var account = _context.Accounts
                .FirstOrDefault(a => a.AccountId == accountId && a.CustomerId == customerId);

            if (account == null)
            {
                ViewBag.Error = "Account not found.";
                var accounts = _context.Accounts
                    .Where(a => a.CustomerId == customerId)
                    .ToList();
                return View(accounts);
            }

            // Check if sufficient balance
            if (account.Balance < amount)
            {
                ViewBag.Error = $"Insufficient balance. Current balance: {account.Balance:C}";
                var accounts = _context.Accounts
                    .Where(a => a.CustomerId == customerId)
                    .ToList();
                return View(accounts);
            }

            // Deduct amount from balance
            account.Balance -= amount;

            // Create transaction record
            var transaction = new Transaction
            {
                AccountId = accountId,
                TransactionType = "WITHDRAWAL",
                Amount = amount,
                TransactionDate = DateTime.Now
            };

            _context.Transactions.Add(transaction);
            _context.SaveChanges();

            // Create audit log
            var auditLog = new AuditLog
            {
                TransactionId = transaction.TransactionId,
                ActionPerformed = "WITHDRAWAL",
                PerformedBy = "Customer",
                LogDate = DateTime.Now
            };

            _context.AuditLogs.Add(auditLog);
            _context.SaveChanges();

            ViewBag.Success = $"Withdrawal of {amount:C} successful! New balance: {account.Balance:C}";
            return RedirectToAction("Dashboard", "Customer");
        }

        // GET: Transaction/ViewTransactions
        public IActionResult ViewTransactions(int accountId = 0)
        {
            // Check if customer is logged in
            if (!IsCustomerLoggedIn())
            {
                return RedirectToAction("Login", "Auth");
            }

            var customerId = GetCurrentCustomerId();

            // Get customer's accounts
            var accounts = _context.Accounts
                .Where(a => a.CustomerId == customerId)
                .ToList();

            if (accounts.Count == 0)
            {
                ViewBag.Error = "You have no accounts.";
                return View(new List<Transaction>());
            }

            // If no account ID specified, use first account
            if (accountId == 0 && accounts.Count > 0)
            {
                accountId = accounts[0].AccountId;
            }

            // Verify account belongs to customer
            var selectedAccount = accounts.FirstOrDefault(a => a.AccountId == accountId);
            if (selectedAccount == null)
            {
                ViewBag.Error = "Account not found.";
                return View(new List<Transaction>());
            }

            // Get transactions for selected account
            var transactions = _context.Transactions
                .Where(t => t.AccountId == accountId)
                .OrderByDescending(t => t.TransactionDate)
                .ToList();

            // Pass data to view
            ViewBag.Accounts = accounts;
            ViewBag.SelectedAccountId = accountId;
            ViewBag.SelectedAccountType = selectedAccount.AccountType;
            ViewBag.SelectedAccountBalance = selectedAccount.Balance;
            ViewBag.TransactionCount = transactions.Count;

            return View(transactions);
        }

        // GET: Transaction/Transfer
        public IActionResult Transfer()
        {
            // Check if customer is logged in
            if (!IsCustomerLoggedIn())
            {
                return RedirectToAction("Login", "Auth");
            }

            var customerId = GetCurrentCustomerId();

            // Get customer's accounts for both from and to selection
            var accounts = _context.Accounts
                .Where(a => a.CustomerId == customerId)
                .ToList();

            if (accounts.Count == 0)
            {
                ViewBag.Error = "You have no accounts. Please create an account first.";
                return View();
            }

            // Pass accounts to view for selection
            ViewBag.Accounts = accounts;
            return View();
        }

        // POST: Transaction/Transfer
        [HttpPost]
        public IActionResult Transfer(int fromAccountId, int toAccountId, decimal amount)
        {
            // Check if customer is logged in
            if (!IsCustomerLoggedIn())
            {
                return RedirectToAction("Login", "Auth");
            }

            var customerId = GetCurrentCustomerId();

            try
            {
                // Validate amount
                if (amount <= 0)
                {
                    ViewBag.Error = "Transfer amount must be greater than 0.";
                    var accounts = _context.Accounts
                        .Where(a => a.CustomerId == customerId)
                        .ToList();
                    ViewBag.Accounts = accounts;
                    return View();
                }

                // Get from account
                var fromAccount = _context.Accounts
                    .FirstOrDefault(a => a.AccountId == fromAccountId && a.CustomerId == customerId);

                if (fromAccount == null)
                {
                    ViewBag.Error = "From account not found.";
                    var accounts = _context.Accounts
                        .Where(a => a.CustomerId == customerId)
                        .ToList();
                    ViewBag.Accounts = accounts;
                    return View();
                }

                // Get to account
                var toAccount = _context.Accounts
                    .FirstOrDefault(a => a.AccountId == toAccountId);

                if (toAccount == null)
                {
                    ViewBag.Error = "To account not found.";
                    var accounts = _context.Accounts
                        .Where(a => a.CustomerId == customerId)
                        .ToList();
                    ViewBag.Accounts = accounts;
                    return View();
                }

                // Prevent transfer to same account
                if (fromAccountId == toAccountId)
                {
                    ViewBag.Error = "Cannot transfer to the same account.";
                    var accounts = _context.Accounts
                        .Where(a => a.CustomerId == customerId)
                        .ToList();
                    ViewBag.Accounts = accounts;
                    return View();
                }

                // Check if sufficient balance
                if (fromAccount.Balance < amount)
                {
                    ViewBag.Error = $"Insufficient balance. Your balance: {fromAccount.Balance:C}, Required: {amount:C}";
                    var accounts = _context.Accounts
                        .Where(a => a.CustomerId == customerId)
                        .ToList();
                    ViewBag.Accounts = accounts;
                    return View();
                }

                // Process transfer
                fromAccount.Balance -= amount;
                toAccount.Balance += amount;

                // Create debit transaction (TRANSFER_OUT)
                var debitTransaction = new Transaction
                {
                    AccountId = fromAccountId,
                    TransactionType = "TRANSFER_OUT",
                    Amount = amount,
                    TransactionDate = DateTime.Now
                };

                _context.Transactions.Add(debitTransaction);

                // Create credit transaction (TRANSFER_IN)
                var creditTransaction = new Transaction
                {
                    AccountId = toAccountId,
                    TransactionType = "TRANSFER_IN",
                    Amount = amount,
                    TransactionDate = DateTime.Now
                };

                _context.Transactions.Add(creditTransaction);

                // Save all changes
                _context.SaveChanges();

                // Create audit log for transfer
                var auditLog = new AuditLog
                {
                    TransactionId = null,
                    ActionPerformed = "TRANSFER",
                    PerformedBy = "Customer",
                    LogDate = DateTime.Now
                };

                _context.AuditLogs.Add(auditLog);
                _context.SaveChanges();

                ViewBag.Success = $"Transfer of {amount:C} successful! From Account {fromAccountId} to Account {toAccountId}.";
                return RedirectToAction("Dashboard", "Customer");
            }
            catch (Exception ex)
            {
                ViewBag.Error = $"Error processing transfer: {ex.Message}";
                var accounts = _context.Accounts
                    .Where(a => a.CustomerId == customerId)
                    .ToList();
                ViewBag.Accounts = accounts;
                return View();
            }
        }
    }
}
