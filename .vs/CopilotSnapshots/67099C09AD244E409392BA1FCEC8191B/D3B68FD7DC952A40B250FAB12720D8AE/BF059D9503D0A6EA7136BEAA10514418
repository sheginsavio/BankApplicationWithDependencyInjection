@model List<Loan>

@{
    ViewData["Title"] = "My Loans";
}

<div class="container mt-5">
    <div class="row mb-4">
        <div class="col-md-12">
            <h2>My Loan Applications</h2>
        </div>
    </div>

    <!-- Loan Summary Cards -->
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card text-white bg-primary">
                <div class="card-body">
                    <h5 class="card-title">Total Loans</h5>
                    <h3>@ViewBag.TotalLoans</h3>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-white bg-warning">
                <div class="card-body">
                    <h5 class="card-title">Applied</h5>
                    <h3>@ViewBag.AppliedLoans</h3>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-white bg-success">
                <div class="card-body">
                    <h5 class="card-title">Approved</h5>
                    <h3>@ViewBag.ApprovedLoans</h3>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-white bg-danger">
                <div class="card-body">
                    <h5 class="card-title">Rejected</h5>
                    <h3>@ViewBag.RejectedLoans</h3>
                </div>
            </div>
        </div>
    </div>

    <!-- Loans Table -->
    <div class="row">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">Loan Details</h5>
                </div>
                <div class="card-body">
                    @if (Model.Count > 0)
                    {
                        <table class="table table-hover">
                            <thead class="table-light">
                                <tr>
                                    <th>Loan ID</th>
                                    <th>Loan Amount</th>
                                    <th>Interest Rate</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var loan in Model)
                                {
                                    <tr>
                                        <td>@loan.LoanId</td>
                                        <td>@loan.LoanAmount.ToString("C")</td>
                                        <td>
                                            @if (loan.InterestRate > 0)
                                            {
                                                <text>@loan.InterestRate.ToString("F2")%</text>
                                            }
                                            else
                                            {
                                                <span class="text-muted">Pending</span>
                                            }
                                        </td>
                                        <td>
                                            @if (loan.LoanStatus == "APPLIED")
                                            {
                                                <span class="badge bg-warning text-dark">@loan.LoanStatus</span>
                                            }
                                            else if (loan.LoanStatus == "APPROVED")
                                            {
                                                <span class="badge bg-success">@loan.LoanStatus</span>
                                            }
                                            else if (loan.LoanStatus == "REJECTED")
                                            {
                                                <span class="badge bg-danger">@loan.LoanStatus</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                    else
                    {
                        <p class="text-muted">No loans found. <a href="/Loan/ApplyLoan">Apply for a loan</a></p>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Action Buttons -->
    <div class="row mt-4">
        <div class="col-md-12">
            <a href="/Loan/ApplyLoan" class="btn btn-info">Apply for New Loan</a>
            <a href="/Customer/Dashboard" class="btn btn-primary">Back to Dashboard</a>
        </div>
    </div>
</div>
