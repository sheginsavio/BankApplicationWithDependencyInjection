@{
    ViewData["Title"] = "Apply for Loan";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-header bg-info text-white">
                    <h4 class="mb-0">Apply for Loan</h4>
                </div>
                <div class="card-body p-4">
                    @if (ViewBag.Error != null)
                    {
                        <div class="alert alert-danger" role="alert">
                            @ViewBag.Error
                        </div>
                    }

                    @if (ViewBag.Success != null)
                    {
                        <div class="alert alert-success" role="alert">
                            @ViewBag.Success
                        </div>
                    }

                    <form method="post" action="/Loan/ApplyLoan">
                        <div class="mb-3">
                            <label for="loanAmount" class="form-label">Loan Amount</label>
                            <input type="number" class="form-control" id="loanAmount" name="loanAmount" placeholder="Enter loan amount" step="0.01" min="0.01" required>
                            <small class="form-text text-muted">Amount must be greater than 0</small>
                        </div>

                        <div class="alert alert-info" role="alert">
                            <strong>Note:</strong> 
                            <ul class="mb-0">
                                <li>Your loan application will be reviewed by our team.</li>
                                <li>Once approved, the loan amount will be credited to your account.</li>
                                <li>Interest rate will be determined after approval.</li>
                            </ul>
                        </div>

                        <button type="submit" class="btn btn-info w-100">Submit Application</button>
                    </form>

                    <hr>

                    <p class="text-center">
                        <a href="/Loan/ViewLoans">View My Loans</a>
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>
