@model List<Account>

@{
    ViewData["Title"] = "Withdraw Money";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-header bg-danger text-white">
                    <h4 class="mb-0">Withdraw Money</h4>
                </div>
                <div class="card-body p-4">
                    @if (ViewBag.Error != null)
                    {
                        <div class="alert alert-danger" role="alert">
                            @ViewBag.Error
                        </div>
                    }

                    @if (ViewBag.Success != null)
                    {
                        <div class="alert alert-success" role="alert">
                            @ViewBag.Success
                        </div>
                    }

                    @if (Model != null && Model.Count > 0)
                    {
                        <form method="post" action="/Transaction/Withdraw">
                            <div class="mb-3">
                                <label for="accountId" class="form-label">Select Account</label>
                                <select class="form-select" id="accountId" name="accountId" required onchange="updateAccountInfo()">
                                    <option value="">-- Select an Account --</option>
                                    @foreach (var account in Model)
                                    {
                                        <option value="@account.AccountId" data-type="@account.AccountType" data-balance="@account.Balance">
                                            @account.AccountType - Balance: @account.Balance.ToString("C")
                                        </option>
                                    }
                                </select>
                            </div>

                            <div class="mb-3">
                                <label for="amount" class="form-label">Withdrawal Amount</label>
                                <input type="number" class="form-control" id="amount" name="amount" placeholder="Enter amount" step="0.01" min="0.01" required>
                                <small class="form-text text-muted">Amount must be greater than 0 and not exceed your balance</small>
                            </div>

                            <div class="alert alert-warning" role="alert">
                                <strong>Important:</strong> You can only withdraw if you have sufficient balance. The amount will be deducted from your account immediately.
                            </div>

                            <button type="submit" class="btn btn-danger w-100">Withdraw</button>
                        </form>
                    }

                    <hr>

                    <p class="text-center">
                        <a href="/Customer/Dashboard">Back to Dashboard</a>
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    function updateAccountInfo() {
        const select = document.getElementById('accountId');
        const selectedOption = select.options[select.selectedIndex];
        if (selectedOption.value) {
            const accountType = selectedOption.getAttribute('data-type');
            const balance = selectedOption.getAttribute('data-balance');
            console.log('Account Type: ' + accountType + ', Balance: ' + balance);
        }
    }
</script>
