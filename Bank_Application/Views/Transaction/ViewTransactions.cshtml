@model List<Transaction>

@{
    ViewData["Title"] = "View Transactions";
}

<div class="container mt-5">
    <div class="row mb-4">
        <div class="col-md-12">
            <h2>Transaction History</h2>
        </div>
    </div>

    <!-- Account Selection and Summary -->
    <div class="row mb-4">
        <div class="col-md-4">
            <div class="card text-white bg-primary">
                <div class="card-body">
                    <h5 class="card-title">Selected Account</h5>
                    <p>@ViewBag.SelectedAccountType</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card text-white bg-success">
                <div class="card-body">
                    <h5 class="card-title">Current Balance</h5>
                    <h3>@ViewBag.SelectedAccountBalance.ToString("C")</h3>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card text-white bg-info">
                <div class="card-body">
                    <h5 class="card-title">Total Transactions</h5>
                    <h3>@ViewBag.TransactionCount</h3>
                </div>
            </div>
        </div>
    </div>

    <!-- Account Switcher -->
    <div class="row mb-4">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">Switch Account</h5>
                </div>
                <div class="card-body">
                    @if (ViewBag.Accounts != null && ViewBag.Accounts.Count > 0)
                    {
                        <div class="btn-group" role="group">
                            @foreach (var account in ViewBag.Accounts)
                            {
                                var isActive = account.AccountId == ViewBag.SelectedAccountId;
                                <a href="/Transaction/ViewTransactions?accountId=@account.AccountId" 
                                   class="btn @(isActive ? "btn-primary" : "btn-outline-primary")">
                                    @account.AccountType (@account.Balance.ToString("C"))
                                </a>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Transactions Table -->
    <div class="row">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">Transaction List</h5>
                </div>
                <div class="card-body">
                    @if (Model.Count > 0)
                    {
                        <table class="table table-hover">
                            <thead class="table-light">
                                <tr>
                                    <th>Transaction ID</th>
                                    <th>Type</th>
                                    <th>Amount</th>
                                    <th>Date & Time</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var transaction in Model)
                                {
                                    <tr>
                                        <td>@transaction.TransactionId</td>
                                        <td>
                                            @if (transaction.TransactionType == "DEPOSIT")
                                            {
                                                <span class="badge bg-success">@transaction.TransactionType</span>
                                            }
                                            else if (transaction.TransactionType == "WITHDRAWAL")
                                            {
                                                <span class="badge bg-danger">@transaction.TransactionType</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-info">@transaction.TransactionType</span>
                                            }
                                        </td>
                                        <td>
                                            @if (transaction.TransactionType == "DEPOSIT")
                                            {
                                                <span class="text-success">+@transaction.Amount.ToString("C")</span>
                                            }
                                            else
                                            {
                                                <span class="text-danger">-@transaction.Amount.ToString("C")</span>
                                            }
                                        </td>
                                        <td>@transaction.TransactionDate.ToString("yyyy-MM-dd HH:mm:ss")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                    else
                    {
                        <p class="text-muted text-center">No transactions found for this account.</p>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Back Button -->
    <div class="row mt-4">
        <div class="col-md-12">
            <a href="/Customer/Dashboard" class="btn btn-primary">Back to Dashboard</a>
        </div>
    </div>
</div>
