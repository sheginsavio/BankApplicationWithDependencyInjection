@{
    ViewData["Title"] = "Transfer Money Between Accounts";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow">
                <div class="card-header bg-info text-white">
                    <h4 class="mb-0">Transfer Money Between Accounts</h4>
                </div>
                <div class="card-body p-4">
                    @if (ViewBag.Error != null)
                    {
                        <div class="alert alert-danger" role="alert">
                            @ViewBag.Error
                        </div>
                    }

                    @if (ViewBag.Success != null)
                    {
                        <div class="alert alert-success" role="alert">
                            @ViewBag.Success
                        </div>
                    }

                    @if (ViewBag.Accounts != null && ViewBag.Accounts.Count > 0)
                    {
                        <form method="post" action="/Transaction/Transfer">
                            <div class="mb-3">
                                <label for="fromAccountId" class="form-label">From Account</label>
                                <select class="form-select" id="fromAccountId" name="fromAccountId" required onchange="updateFromAccountDetails()">
                                    <option value="">-- Select From Account --</option>
                                    @foreach (var account in ViewBag.Accounts)
                                    {
                                        <option value="@account.AccountId" data-type="@account.AccountType" data-balance="@account.Balance">
                                            Account #@account.AccountId - @account.AccountType - Balance: @account.Balance.ToString("C")
                                        </option>
                                    }
                                </select>
                            </div>

                            <!-- From Account Details -->
                            <div class="card mb-3" id="fromAccountDetails" style="display:none;">
                                <div class="card-body">
                                    <h6>Account Type: <span id="fromAccountType">-</span></h6>
                                    <h6>Current Balance: <span id="fromAccountBalance" class="text-success">-</span></h6>
                                </div>
                            </div>

                            <div class="mb-3">
                                <label for="toAccountId" class="form-label">To Account</label>
                                <select class="form-select" id="toAccountId" name="toAccountId" required onchange="updateToAccountDetails()">
                                    <option value="">-- Select To Account --</option>
                                    @foreach (var account in ViewBag.Accounts)
                                    {
                                        <option value="@account.AccountId" data-type="@account.AccountType" data-balance="@account.Balance">
                                            Account #@account.AccountId - @account.AccountType - Balance: @account.Balance.ToString("C")
                                        </option>
                                    }
                                </select>
                            </div>

                            <!-- To Account Details -->
                            <div class="card mb-3" id="toAccountDetails" style="display:none;">
                                <div class="card-body">
                                    <h6>Account Type: <span id="toAccountType">-</span></h6>
                                    <h6>Current Balance: <span id="toAccountBalance" class="text-success">-</span></h6>
                                </div>
                            </div>

                            <div class="mb-3">
                                <label for="amount" class="form-label">Transfer Amount</label>
                                <input type="number" class="form-control" id="amount" name="amount" placeholder="Enter amount to transfer" step="0.01" min="0.01" required>
                                <small class="form-text text-muted" id="amountHelper">Select from account to see maximum amount</small>
                            </div>

                            <div class="alert alert-warning" role="alert">
                                <strong>Important:</strong>
                                <ul class="mb-0">
                                    <li>Transfer amount must be greater than 0</li>
                                    <li>Cannot exceed your from account balance</li>
                                    <li>Cannot transfer to the same account</li>
                                    <li>Both accounts must exist</li>
                                </ul>
                            </div>

                            <button type="submit" class="btn btn-info w-100">Transfer Money</button>
                        </form>
                    }

                    <hr>

                    <p class="text-center">
                        <a href="/Customer/Dashboard">Back to Dashboard</a> | 
                        <a href="/Transaction/ViewTransactions">View Transactions</a>
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    function updateFromAccountDetails() {
        const select = document.getElementById('fromAccountId');
        const selectedOption = select.options[select.selectedIndex];

        if (selectedOption.value) {
            const accountType = selectedOption.getAttribute('data-type');
            const balance = selectedOption.getAttribute('data-balance');

            document.getElementById('fromAccountType').textContent = accountType;
            document.getElementById('fromAccountBalance').textContent = new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD' }).format(balance);
            document.getElementById('fromAccountDetails').style.display = 'block';

            document.getElementById('amountHelper').textContent = 'Maximum amount you can transfer: ' + new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD' }).format(balance);
            document.getElementById('amount').max = balance;
        } else {
            document.getElementById('fromAccountDetails').style.display = 'none';
        }
    }

    function updateToAccountDetails() {
        const select = document.getElementById('toAccountId');
        const selectedOption = select.options[select.selectedIndex];

        if (selectedOption.value) {
            const accountType = selectedOption.getAttribute('data-type');
            const balance = selectedOption.getAttribute('data-balance');

            document.getElementById('toAccountType').textContent = accountType;
            document.getElementById('toAccountBalance').textContent = new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD' }).format(balance);
            document.getElementById('toAccountDetails').style.display = 'block';
        } else {
            document.getElementById('toAccountDetails').style.display = 'none';
        }
    }
</script>
