@{
    ViewData["Title"] = "Transaction Report";
}

<div class="container-fluid mt-5">
    <div class="row mb-4">
        <div class="col-md-12">
            <h2>Financial Transaction Report</h2>
            <p class="text-muted">Generated on: @DateTime.Now.ToString("yyyy-MM-dd HH:mm:ss")</p>
        </div>
    </div>

    <!-- Report Summary Cards -->
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card text-white bg-primary">
                <div class="card-body">
                    <h5 class="card-title">Total Transactions</h5>
                    <h3>@ViewBag.TotalTransactions</h3>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-white bg-success">
                <div class="card-body">
                    <h5 class="card-title">Total Amount</h5>
                    <h3>@ViewBag.TotalAmount.ToString("C")</h3>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-white bg-info">
                <div class="card-body">
                    <h5 class="card-title">Deposits</h5>
                    <h3>@ViewBag.DepositCount</h3>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-white bg-warning">
                <div class="card-body">
                    <h5 class="card-title">Withdrawals</h5>
                    <h3>@ViewBag.WithdrawalCount</h3>
                </div>
            </div>
        </div>
    </div>

    <!-- Transactions Table -->
    <div class="row">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">Transaction Details</h5>
                </div>
                <div class="card-body">
                    @if (Model != null && Model.Count > 0)
                    {
                        <div class="table-responsive">
                            <table class="table table-hover table-striped">
                                <thead class="table-light">
                                    <tr>
                                        <th>Transaction ID</th>
                                        <th>Account ID</th>
                                        <th>Customer Name</th>
                                        <th>Transaction Type</th>
                                        <th>Amount</th>
                                        <th>Date & Time</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var transaction in Model)
                                    {
                                        <tr>
                                            <td>@transaction.TransactionId</td>
                                            <td>@transaction.AccountId</td>
                                            <td>@transaction.CustomerName</td>
                                            <td>
                                                @if (transaction.TransactionType == "DEPOSIT")
                                                {
                                                    <span class="badge bg-success">@transaction.TransactionType</span>
                                                }
                                                else if (transaction.TransactionType == "WITHDRAWAL")
                                                {
                                                    <span class="badge bg-danger">@transaction.TransactionType</span>
                                                }
                                                else if (transaction.TransactionType == "TRANSFER")
                                                {
                                                    <span class="badge bg-info">@transaction.TransactionType</span>
                                                }
                                            </td>
                                            <td>
                                                @if (transaction.TransactionType == "DEPOSIT" || transaction.TransactionType == "TRANSFER")
                                                {
                                                    <span class="text-success">+@transaction.Amount.ToString("C")</span>
                                                }
                                                else
                                                {
                                                    <span class="text-danger">-@transaction.Amount.ToString("C")</span>
                                                }
                                            </td>
                                            <td>@transaction.TransactionDate.ToString("yyyy-MM-dd HH:mm:ss")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-info" role="alert">
                            No transactions found.
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Export and Navigation -->
    <div class="row mt-4">
        <div class="col-md-12">
            <button class="btn btn-primary" onclick="window.print()">Print Report</button>
            <a href="/Report/GetAuditLogs" class="btn btn-info">View Audit Logs</a>
            <a href="/Auth/Logout" class="btn btn-danger">Logout</a>
        </div>
    </div>
</div>
