@model Customer

@{
    ViewData["Title"] = "Update Profile";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-header bg-warning text-dark">
                    <h4 class="mb-0">Update Your Profile</h4>
                </div>
                <div class="card-body p-4">
                    @if (ViewBag.Error != null)
                    {
                        <div class="alert alert-danger" role="alert">
                            @ViewBag.Error
                        </div>
                    }

                    @if (ViewBag.Success != null)
                    {
                        <div class="alert alert-success" role="alert">
                            @ViewBag.Success
                        </div>
                    }

                    <form method="post" action="/Customer/UpdateProfile">
                        <input type="hidden" name="customerId" value="@Model.CustomerId">

                        <div class="mb-3">
                            <label for="name" class="form-label">Full Name</label>
                            <input type="text" class="form-control" id="name" name="name" value="@Model.Name" required>
                        </div>

                        <div class="mb-3">
                            <label for="email" class="form-label">Email Address</label>
                            <input type="email" class="form-control" id="email" name="email" value="@Model.Email" required>
                            <small class="form-text text-muted">This email is used for login</small>
                        </div>

                        <div class="mb-3">
                            <label for="contactInfo" class="form-label">Contact Information</label>
                            <input type="text" class="form-control" id="contactInfo" name="contactInfo" value="@Model.ContactInfo" required>
                        </div>

                        <button type="submit" class="btn btn-warning w-100">Update Profile</button>
                    </form>

                    <hr>

                    <p class="text-center"><a href="/Customer/Dashboard">Back to Dashboard</a></p>
                </div>
            </div>
        </div>
    </div>
</div>
