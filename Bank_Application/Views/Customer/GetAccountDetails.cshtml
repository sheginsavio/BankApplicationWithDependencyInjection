@model List<Transaction>

@{
    ViewData["Title"] = "Account Details";
}

<div class="container mt-5">
    <div class="row mb-4">
        <div class="col-md-12">
            <h2>Account Details</h2>
        </div>
    </div>

    <!-- Account Summary -->
    <div class="row mb-4">
        <div class="col-md-4">
            <div class="card text-white bg-primary">
                <div class="card-body">
                    <h5 class="card-title">Account ID</h5>
                    <h3>@ViewBag.AccountId</h3>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card text-white bg-info">
                <div class="card-body">
                    <h5 class="card-title">Account Type</h5>
                    <h3>@ViewBag.AccountType</h3>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card text-white bg-success">
                <div class="card-body">
                    <h5 class="card-title">Current Balance</h5>
                    <h3>@ViewBag.Balance.ToString("C")</h3>
                </div>
            </div>
        </div>
    </div>

    <!-- Transactions Table -->
    <div class="row">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">Transaction History (@ViewBag.TransactionCount transactions)</h5>
                </div>
                <div class="card-body">
                    @if (Model.Count > 0)
                    {
                        <table class="table table-hover">
                            <thead class="table-light">
                                <tr>
                                    <th>Transaction ID</th>
                                    <th>Type</th>
                                    <th>Amount</th>
                                    <th>Date</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var transaction in Model)
                                {
                                    <tr>
                                        <td>@transaction.TransactionId</td>
                                        <td>
                                            @if (transaction.TransactionType == "DEPOSIT")
                                            {
                                                <span class="badge bg-success">@transaction.TransactionType</span>
                                            }
                                            else if (transaction.TransactionType == "WITHDRAWAL")
                                            {
                                                <span class="badge bg-danger">@transaction.TransactionType</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-info">@transaction.TransactionType</span>
                                            }
                                        </td>
                                        <td>@transaction.Amount.ToString("C")</td>
                                        <td>@transaction.TransactionDate.ToString("yyyy-MM-dd HH:mm")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                    else
                    {
                        <p class="text-muted">No transactions found for this account.</p>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Back Button -->
    <div class="row mt-4">
        <div class="col-md-12">
            <a href="/Customer/Dashboard" class="btn btn-primary">Back to Dashboard</a>
        </div>
    </div>
</div>
