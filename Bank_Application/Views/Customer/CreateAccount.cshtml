@{
    ViewData["Title"] = "Create Account";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-header bg-success text-white">
                    <h4 class="mb-0">Create New Account</h4>
                </div>
                <div class="card-body p-4">
                    @if (ViewBag.Error != null)
                    {
                        <div class="alert alert-danger" role="alert">
                            @ViewBag.Error
                        </div>
                    }

                    @if (ViewBag.Success != null)
                    {
                        <div class="alert alert-success" role="alert">
                            @ViewBag.Success
                        </div>
                    }

                    <form method="post" action="/Customer/CreateAccount">
                        <div class="mb-3">
                            <label for="accountType" class="form-label">Account Type</label>
                            <select class="form-select" id="accountType" name="accountType" required>
                                <option value="">-- Select Account Type --</option>
                                <option value="SAVINGS">Savings Account</option>
                                <option value="CURRENT">Current Account</option>
                            </select>
                        </div>

                        <div class="alert alert-info" role="alert">
                            <strong>Note:</strong> Initial balance will be set to 0. You can deposit funds after account creation.
                        </div>

                        <button type="submit" class="btn btn-success w-100">Create Account</button>
                    </form>

                    <hr>

                    <p class="text-center"><a href="/Customer/Dashboard">Back to Dashboard</a></p>
                </div>
            </div>
        </div>
    </div>
</div>
