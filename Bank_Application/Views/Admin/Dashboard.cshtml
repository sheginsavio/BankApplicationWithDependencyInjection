@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="container mt-5">
    <div class="row mb-4">
        <div class="col-md-12">
            <h2>Admin Dashboard</h2>
            <p class="text-muted">Welcome to the Banking System Administration Panel</p>
        </div>
    </div>

    <!-- Admin Actions Cards -->
    <div class="row mb-4">
        <div class="col-md-4">
            <div class="card shadow">
                <div class="card-body text-center">
                    <div style="font-size: 3rem; color: #007bff; margin-bottom: 15px;">
                        <i class="fas fa-exchange-alt"></i>
                    </div>
                    <h5 class="card-title">Transaction Report</h5>
                    <p class="card-text">View all transactions in the system</p>
                    <a href="/Report/GenerateTransactionReport" class="btn btn-primary">View Report</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card shadow">
                <div class="card-body text-center">
                    <div style="font-size: 3rem; color: #28a745; margin-bottom: 15px;">
                        <i class="fas fa-audit"></i>
                    </div>
                    <h5 class="card-title">Audit Logs</h5>
                    <p class="card-text">View system audit and activity logs</p>
                    <a href="/Report/GetAuditLogs" class="btn btn-success">View Logs</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card shadow">
                <div class="card-body text-center">
                    <div style="font-size: 3rem; color: #dc3545; margin-bottom: 15px;">
                        <i class="fas fa-sign-out-alt"></i>
                    </div>
                    <h5 class="card-title">Logout</h5>
                    <p class="card-text">Sign out from Admin Panel</p>
                    <a href="/Auth/Logout" class="btn btn-danger">Logout</a>
                </div>
            </div>
        </div>
    </div>

    <!-- System Information -->
    <div class="row">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">Admin Panel Features</h5>
                </div>
                <div class="card-body">
                    <ul>
                        <li><strong>Transaction Report:</strong> Monitor all customer deposits, withdrawals, and transfers</li>
                        <li><strong>Audit Logs:</strong> Track all system activities including loan approvals, rejections, and repayments</li>
                        <li><strong>Security:</strong> All reports are restricted to Admin access only</li>
                        <li><strong>Tracking:</strong> Every action is logged for compliance and audit purposes</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Add Font Awesome for icons -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
